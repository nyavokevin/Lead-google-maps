# ─── SerpApi ─────────────────────────────────────────────────────────────────
SERPAPI_KEY=your_serpapi_key_here

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# (do NOT use your real Gmail password here)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Ny Avo Kevin <your_email@gmail.com>

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
# Create a free account at https://www.twilio.com
# Use the Sandbox number for testing, or a verified number for production
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_WA_FROM=whatsapp:+14155238886
